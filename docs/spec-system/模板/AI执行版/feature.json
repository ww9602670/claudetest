{
  "feature_id": "<feature-id>",
  "status": "draft",
  "phase": "phase1",
  "phase_gate_approved": false,
  "phase_gate_approved_by": "",
  "phase_gate_approved_at": "",
  "phase_gate_note": "",

  "owner": "",

  "approved_by": "",
  "approved_at": "",
  "approved_method": "",
  "approved_note": "",

  "allowed_paths": [
    "features/<feature-id>/",
    "src/<相关目录>/"
  ],
  "forbidden_paths": [
    "src/core/",
    "config/production/"
  ],

  "required_checks": [
    {
      "id": "lint",
      "description": "代码风格检查",
      "command_windows": "npm run lint",
      "command_bash": "npm run lint"
    },
    {
      "id": "test",
      "description": "单元测试",
      "command_windows": "npm test",
      "command_bash": "npm test"
    }
  ],

  "max_fix_rounds": 3,
  "fix_round_current": 0,
  "repeat_failure_stop_threshold": 2,

  "stop_conditions": [
    "all required_checks pass",
    "fix_round_current >= max_fix_rounds",
    "unrecoverable error encountered"
  ],

  "human_review_required_when": [
    "status transitions to approved",
    "fix_round_current >= repeat_failure_stop_threshold",
    "status set to blocked"
  ],

  "evidence_dir": "features/<feature-id>/evidence/",

  "block_reason": "",

  "created_at": "YYYY-MM-DDTHH:MM:SSZ",
  "updated_at": "YYYY-MM-DDTHH:MM:SSZ"
}
